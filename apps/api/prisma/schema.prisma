generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Phase 0: database foundation only.
// Marketplace domain models (User, Provider, Service, Booking, Payment, Review, etc.)
// will be added in later phases via incremental Prisma migrations.
// Prefer UUID primary keys (@id @default(uuid()) or @default(cuid())) for public identifiers.
