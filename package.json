{
  "name": "local-service-marketplace",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-tenant Local Service Marketplace monorepo",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm run --parallel --filter @local-service-marketplace/web --filter @local-service-marketplace/api dev",
    "dev:web": "pnpm --filter @local-service-marketplace/web dev",
    "dev:api": "pnpm --filter @local-service-marketplace/api dev",
    "build": "pnpm run --filter @local-service-marketplace/shared-types build && pnpm run --filter @local-service-marketplace/api build && pnpm run --filter @local-service-marketplace/web build",
    "lint": "pnpm run --recursive --filter \"./apps/*\" --filter \"./packages/*\" lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "pnpm run --recursive --filter \"./apps/*\" --filter \"./packages/*\" typecheck",
    "test": "pnpm run --recursive --filter \"./apps/*\" test",
    "db:generate": "pnpm --filter @local-service-marketplace/api db:generate",
    "db:migrate": "pnpm --filter @local-service-marketplace/api db:migrate",
    "db:seed": "pnpm --filter @local-service-marketplace/api db:seed",
    "db:studio": "pnpm --filter @local-service-marketplace/api db:studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.39.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
