{
  "name": "@local-service-marketplace/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types and API contract foundations",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"No tests for shared-types yet\""
  },
  "devDependencies": {
    "@local-service-marketplace/config": "workspace:*",
    "@local-service-marketplace/eslint-config": "workspace:*",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3"
  }
}
